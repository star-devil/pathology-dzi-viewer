{
  "name": "dzi-viewer-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "病理切片 DZI 标注预览组件库 — Monorepo",
  "author": "Egg",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @pathology/dzi-viewer-core build",
    "build:vue": "pnpm --filter @pathology/dzi-viewer-vue build",
    "dev:core": "pnpm --filter @pathology/dzi-viewer-core dev",
    "dev:vue": "pnpm --filter @pathology/dzi-viewer-vue dev",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  },
  "pnpm": {
    "overrides": {
      "human-id": "3.0.1"
    }
  }
}
